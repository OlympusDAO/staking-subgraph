{
  "name": "staking-subgraph",
  "version": "1.0.0",
  "description": "Subgraph to track staking activity",
  "main": "index.js",
  "author": "Jem <0x0xjem@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/OlympusDAO/staking-subgraph",
  "scripts": {
    "codegen": "graph codegen && eslint --fix --ext .ts generated",
    "build": "graph build",
    "lint": "eslint --fix --ext .ts src generated",
    "lint:check": "eslint --max-warnings 0 --ext .ts src generated",
    "deploy": "source .subgraph-version && graph deploy --node https://api.thegraph.com/deploy/ --ipfs https://api.thegraph.com/ipfs/ olympusdao/staking",
    "deploy:dev": "source .subgraph-version && graph deploy --studio staking --version-label $SUBGRAPH_VERSION",
    "test": "graph test --version 0.5.3",
    "test:force": "yarn test --recompile",
    "auth": "source .env && graph auth --product hosted-service $GRAPH_TOKEN",
    "auth:dev": "source .env && graph auth --product subgraph-studio $GRAPH_STUDIO_TOKEN",
    "preinstall": "npx only-allow@1.2.2 pnpm"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.98.1",
    "@graphprotocol/graph-ts": "^0.28.0",
    "assemblyscript-json": "^1.1.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.26.0",
    "@typescript-eslint/parser": "^5.26.0",
    "assemblyscript": "0.19.10",
    "eslint": "^8.16.0",
    "eslint-plugin-simple-import-sort": "^8.0.0",
    "matchstick-as": "^0.5.0",
    "prettier": "^2.6.2",
    "typescript": "^4.6.4"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10.33.0",
    "npm": "use-pnpm",
    "yarn": "use-pnpm"
  },
  "pnpm": {
    "overrides": {
      "ajv": ">=6.14.0",
      "ajv@<6.14.0": ">=6.14.0",
      "@pnpm/npm-conf": ">=3.0.2",
      "@pnpm/npm-conf@<3.0.2": ">=3.0.2",
      "axios": ">=1.15.0",
      "axios@<0.30.0": ">=0.30.0",
      "axios@<=0.30.2": ">=0.30.3",
      "axios@>=0.8.1 <0.28.0": ">=0.28.0",
      "brace-expansion": ">=1.1.13",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=1.0.0 <=1.1.11": ">=1.1.12",
      "braces": ">=3.0.3",
      "braces@<3.0.3": ">=3.0.3",
      "cross-spawn": ">=7.0.5",
      "cross-spawn@>=7.0.0 <7.0.5": ">=7.0.5",
      "ejs": ">=3.1.10",
      "ejs@<3.1.10": ">=3.1.10",
      "flatted": ">=3.4.2",
      "flatted@<3.4.0": ">=3.4.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "follow-redirects": ">=1.15.6",
      "follow-redirects@<1.15.4": ">=1.15.4",
      "follow-redirects@<=1.15.5": ">=1.15.6",
      "glob": ">=10.5.0",
      "glob@>=11.0.0 <11.1.0": ">=11.1.0",
      "glob@<10.5.0": ">=10.5.0",
      "immutable": ">=5.1.5",
      "immutable@>=5.0.0 <5.1.5": ">=5.1.5",
      "js-yaml": ">=4.1.1",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "lodash.trim": "4.18.0",
      "lodash.trimend": "4.18.0",
      "micromatch": ">=4.0.8",
      "micromatch@<4.0.8": ">=4.0.8",
      "minimatch": ">=3.1.4",
      "minimatch@<3.1.3": ">=3.1.3",
      "minimatch@<3.1.4": ">=3.1.4",
      "picomatch": ">=2.3.2",
      "picomatch@<2.3.2": ">=2.3.2",
      "semver": ">=7.5.2",
      "semver@>=7.0.0 <7.5.2": ">=7.5.2",
      "tmp@<=0.2.3": ">=0.2.4",
      "undici@<5.29.0": ">=5.29.0",
      "undici@>=6.0.0 <6.24.0": ">=6.24.0",
      "undici@>=7.0.0 <7.24.0": ">=7.24.0",
      "word-wrap": ">=1.2.4",
      "word-wrap@<1.2.4": ">=1.2.4",
      "yaml": ">=2.8.3",
      "yaml@>=1.0.0 <1.10.3": ">=1.10.3",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "axios@<1.15.0": ">=1.15.0",
      "apisauce>axios": ">=1.15.0"
    }
  }
}
